{
  "name": "moveonapp-pos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "config:generate": "node scripts/generate-runtime-config.mjs",
    "predev": "node scripts/generate-runtime-config.mjs",
    "prebuild": "node scripts/generate-runtime-config.mjs",
    "pretypecheck": "node scripts/generate-runtime-config.mjs",
    "dev": "ng serve pos-angular",
    "build": "ng build pos-angular",
    "start": "ng serve pos-angular --configuration production",
    "lint": "ng lint pos-angular",
    "typecheck": "tsc --noEmit && ng build pos-angular --configuration development",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --project-id rmaieqyscchtxxkgxgik > src/infrastructure/supabase/database.types.ts",
    "db:diff": "supabase db diff",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop"
  },
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@supabase/supabase-js": "^2.45.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zod": "^3.23.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.9",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@playwright/test": "^1.47.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^9.16.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "supabase": "^1.200.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.0"
  }
}
