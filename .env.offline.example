# Copia como .env.offline. Este archivo nunca se versiona.
OFFLINE_ADMIN_EMAIL=admin@moveon.local
OFFLINE_ADMIN_PASSWORD=MoveonLocal123!

# Usa el UUID real de la tienda remota para que el lote pueda sincronizarse.
# Si se omite, se usa la tienda demo local y offline:sync rechazara el lote.
OFFLINE_TIENDA_ID=00000000-0000-0000-0000-000000000001
OFFLINE_TIENDA_NAME=MOVEONAPP Tienda Local
