# ============================================
# MOVEONAPP POS — Variables de entorno (Angular)
# ============================================
# La app Angular standalone consume estas claves desde
# `apps/pos-angular/src/environments/environment.ts` (o, idealmente,
# desde un archivo runtime cargado al bootstrap). Mantén este archivo
# como referencia de los valores que la app necesita.
#
# NUNCA committear .env.local al repo.

# --- Supabase (públicas, OK exponer al cliente) ---
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Supabase (privadas, sólo herramientas locales / Edge Functions) ---
# Nunca empaquetar en el bundle Angular ni exponer al navegador.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_DB_URL=postgresql://...

# --- App ---
APP_NAME=MOVEONAPP POS

# --- Billing Provider (v1.1, no necesarias en MVP v1.0) ---
BILLING_PROVIDER=mock
# BILLING_PROVIDER=factus
BILLING_PROVIDER_API_URL=
BILLING_PROVIDER_API_KEY=
BILLING_PROVIDER_RESOLUTION_PREFIX=
BILLING_PROVIDER_RESOLUTION_NUMBER=

# --- Sentry (opcional) ---
SENTRY_DSN=

# --- Feature flags ---
FEATURE_BILLING=false
FEATURE_MULTISEDE_UI=false
FEATURE_RECIPES=false
