# ============================================
# MOVEONAPP POS - Variables de entorno
# ============================================
# Copiar este archivo a .env.local y rellenar valores reales.
# NUNCA committear .env.local al repo.
#
# Vercel:
# - Configurar estas variables en Project Settings > Environment Variables.
# - Como mínimo, Preview y Production necesitan:
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
# - SUPABASE_DB_URL no es necesaria para runtime en Vercel; se usa para
#   migraciones/operación local.

# --- Supabase (públicas, OK exponer) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Supabase (privadas, server-only) ---
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_DB_URL=postgresql://...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MOVEONAPP POS

# --- Billing Provider (v1.1, no necesarias en MVP v1.0) ---
BILLING_PROVIDER=mock
# BILLING_PROVIDER=factus
BILLING_PROVIDER_API_URL=
BILLING_PROVIDER_API_KEY=
BILLING_PROVIDER_RESOLUTION_PREFIX=
BILLING_PROVIDER_RESOLUTION_NUMBER=

# --- Sentry (opcional) ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Feature flags ---
NEXT_PUBLIC_FEATURE_BILLING=false
NEXT_PUBLIC_FEATURE_MULTISEDE_UI=false
NEXT_PUBLIC_FEATURE_RECIPES=false
